# Database
DATABASE_URL=postgresql://username:password@localhost:5432/stock_platform

# API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here
NEWS_API_KEY=your_news_api_key_here
GOOGLE_API_KEY=your_google_gemini_key_here
FRED_API_KEY=your_fred_api_key_here
BLS_API_KEY=your_bls_api_key_here
BEA_API_KEY=your_bea_api_key_here
FMP_API_KEY=your_fmp_api_key_here

# Admin Authentication (IMPORTANT: Generate a strong random key for production)
ADMIN_API_KEY=your_secure_random_admin_key_here

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Application Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
CORS_ORIGINS=["https://yoursite.com","https://admin.yoursite.com"]

# Data Update Intervals (in minutes)
STOCK_DATA_UPDATE_INTERVAL=60
NEWS_UPDATE_INTERVAL=30

# LLM Settings
LLM_MODEL=gemini-2.5-flash
MAX_TOKENS=1000
TEMPERATURE=0.3

# Rate Limiting
REQUESTS_PER_MINUTE=100 